{
  "name": "xml-prompting",
  "version": "1.2.2",
  "description": "CLI that bundles your codebase with an XML meta-prompt for AI planning (Claude, ChatGPT, etc.).",
  "main": "index.js",
  "bin": {
    "xml-prompting": "./index.js"
  },
  "files": [
    "index.js",
    "templates",
    "LICENSE"
  ],
  "scripts": {
    "start": "node index.js",
    "prepack": "node -e \"require('fs').accessSync('templates/meta_prompt.xml')\""
  },
  "keywords": [
    "ai",
    "prompt",
    "llm",
    "cli",
    "codebase",
    "xml",
    "anthropic",
    "claude",
    "context"
  ],
  "author": "Hi9841",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hi9841/xml-prompting.git"
  },
  "bugs": {
    "url": "https://github.com/Hi9841/xml-prompting/issues"
  },
  "homepage": "https://github.com/Hi9841/xml-prompting#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "ignore": "^5.2.4",
    "picocolors": "^1.0.0"
  }
}
